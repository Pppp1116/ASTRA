/// std.math – small numeric helpers.
///
/// These utilities are pure and valid in both hosted and freestanding modes.
fn min_int(a: Int, b: Int) -> Int {
  if a < b {
    return a;
  }
  return b;
}

fn max_int(a: Int, b: Int) -> Int {
  if a > b {
    return a;
  }
  return b;
}

fn clamp_int(x: Int, lo: Int, hi: Int) -> Int {
  if x < lo {
    return lo;
  }
  if x > hi {
    return hi;
  }
  return x;
}

fn abs_int(x: Int) -> Int {
  if x < 0 {
    return -x;
  }
  return x;
}

