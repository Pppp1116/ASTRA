{
  "Function": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "    ${4:// body}",
      "}"
    ],
    "description": "Function declaration"
  },
  "Function with parameters": {
    "prefix": "fn",
    "body": [
      "fn ${1:name}(${2:param1}: ${3:Type1}, ${4:param2}: ${5:Type2}) -> ${6:ReturnType} {",
      "    ${7:// body}",
      "}"
    ],
    "description": "Function declaration with parameters"
  },
  "Struct declaration": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "    ${2:field1}: ${3:Type1},",
      "    ${4:field2}: ${5:Type2},",
      "}"
    ],
    "description": "Struct declaration"
  },
  "Enum declaration": {
    "prefix": "enum",
    "body": [
      "enum ${1:Name} {",
      "    ${2:Variant1},",
      "    ${3:Variant2},",
      "}"
    ],
    "description": "Enum declaration"
  },
  "Let statement": {
    "prefix": "let",
    "body": ["let ${1:name}: ${2:Type} = ${3:value};"],
    "description": "Let statement with type annotation"
  },
  "Mutable let": {
    "prefix": "let mut",
    "body": ["let mut ${1:name}: ${2:Type} = ${3:value};"],
    "description": "Mutable let statement"
  },
  "If statement": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "    ${2:// then branch}",
      "} else {",
      "    ${3:// else branch}",
      "}"
    ],
    "description": "If-else statement"
  },
  "While loop": {
    "prefix": "while",
    "body": [
      "while ${1:condition} {",
      "    ${2:// body}",
      "}"
    ],
    "description": "While loop"
  },
  "For loop": {
    "prefix": "for",
    "body": [
      "for ${1:item} in ${2:iterator} {",
      "    ${3:// body}",
      "}"
    ],
    "description": "For loop"
  },
  "Match statement": {
    "prefix": "match",
    "body": [
      "match ${1:expression} {",
      "    ${2:pattern1} => ${3:result1},",
      "    ${4:pattern2} => ${5:result2},",
      "    _ => ${6:default},",
      "}"
    ],
    "description": "Match statement"
  },
  "Return statement": {
    "prefix": "return",
    "body": ["return ${1:value};"],
    "description": "Return statement"
  },
  "Import statement": {
    "prefix": "import",
    "body": ["import ${1:module};"],
    "description": "Import statement"
  },
  "Extern function": {
    "prefix": "extern",
    "body": ["extern fn ${1:name}(${2:params}) -> ${3:ReturnType};"],
    "description": "Extern function declaration"
  },
  "Async function": {
    "prefix": "async fn",
    "body": [
      "async fn ${1:name}(${2:params}) -> ${3:ReturnType} {",
      "    ${4:// body}",
      "}"
    ],
    "description": "Async function declaration"
  },
  "Await expression": {
    "prefix": "await",
    "body": ["await ${1:expression}"],
    "description": "Await expression"
  },
  "Unsafe block": {
    "prefix": "unsafe",
    "body": [
      "unsafe {",
      "    ${1:// unsafe code}",
      "}"
    ],
    "description": "Unsafe block"
  },
  "Defer statement": {
    "prefix": "defer",
    "body": ["defer ${1:expression};"],
    "description": "Defer statement"
  },
  "Option type": {
    "prefix": "Option",
    "body": ["Option<${1:Type}>"],
    "description": "Option type"
  },
  "None literal": {
    "prefix": "none",
    "body": ["none"],
    "description": "None literal"
  },
  "Type cast": {
    "prefix": "as",
    "body": ["${1:expression} as ${2:Type}"],
    "description": "Type cast"
  },
  "Sizeof expression": {
    "prefix": "sizeof",
    "body": ["sizeof(${1:Type})"],
    "description": "Sizeof expression"
  },
  "Alignof expression": {
    "prefix": "alignof",
    "body": ["alignof(${1:Type})"],
    "description": "Alignof expression"
  }
}
