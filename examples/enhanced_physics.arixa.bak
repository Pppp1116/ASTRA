// Enhanced Physics Example - Demonstrating improved syntax
// This is how physics.arixa would look with proposed syntax enhancements

import std.math;
import std.str;

// Enhanced struct definition (shorthand constructor available)
struct Vec2 {
    x Float,
    y Float,
}

// Enhanced function definitions with expression syntax
fn dot(a Vec2, b Vec2) Float = a.x * b.x + a.y * b.y

fn len2(v Vec2) Float = dot(v, v)

// Enhanced pattern matching with guard clauses
fn classify_speed(v2 Float) Int {
    match v2 {
        speed if speed > 25.0 => 2,
        speed if speed > 10.0 => 1,
        _ => 0,
    }
}

// Enhanced main function with better syntax
fn main() Int {
    // Enhanced vector literal
    pts = [Vec2(3.0, 4.0), Vec2(1.0, 2.0), Vec2(10.0, 0.0)];
    
    // Enhanced for loop with iterator
    mut acc = 0.0;
    for mut pt in pts {
        acc += len2(pt)
    }
    
    // Enhanced if expression
    category = if acc > 50.0 { "high" } else { "normal" }
    
    // Enhanced function calls (no drop needed)
    print(acc);
    print(classify_speed(acc));
    print("Category: " + category);
    
    return 0;
}

// Ultra-enhanced version with method calls and destructuring
fn ultra_enhanced_main() Int {
    // Enhanced vector creation
    pts = [
        Vec2 { x: 3.0, y: 4.0 },
        Vec2 { x: 1.0, y: 2.0 },
        Vec2 { x: 10.0, y: 0.0 }
    ];
    
    // Enhanced for loop with destructuring
    mut acc = 0.0;
    for Vec2 { x, y } in pts {
        acc += x * x + y * y
    }
    
    // Enhanced method calls
    acc.print();
    classify_speed(acc).print();
    
    // Enhanced pattern matching with struct patterns
    match Vec2 { x: acc, y: 0.0 } {
        Vec2 { x, y } if x > 100.0 => print("Very high speed"),
        Vec2 { x, y } if x > 50.0 => print("High speed"),
        Vec2 { x, y } if x > 25.0 => print("Medium speed"),
        Vec2 { x, y } => print("Low speed"),
    }
    
    return 0;
}

// Enhanced utility functions with default parameters
fn create_vector(x Float = 0.0, y Float = 0.0) Vec2 {
    return Vec2 { x, y }
}

fn distance(a Vec2, b Vec2) Float {
    dx = a.x - b.x
    dy = a.y - b.y
    return sqrt(dx * dx + dy * dy)
}

// Enhanced example with named arguments
fn named_arguments_demo() Void {
    // Named arguments would look like:
    // p1 = create_vector(x: 3.0, y: 4.0)
    // p2 = create_vector(y: 2.0)  // x uses default
    
    p1 = create_vector(3.0, 4.0)
    p2 = create_vector(0.0, 2.0)
    
    dist = distance(p1, p2)
    print("Distance: " + str.to_string_float(dist))
}
