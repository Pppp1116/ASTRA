gpu fn scale(alpha Float, input GpuSlice<Float>, out GpuMutSlice<Float>) Void{
  i = gpu.global_id();
  if i < out.len() {
    out[i] = alpha * input[i];
  }
}

fn main() Int{
  alpha = 3.0;
  src: Vec<Float> = vec_from([2.0, 4.0, 6.0, 8.0]);

  dsrc = gpu.copy(src);
  dout: GpuBuffer<Float> = gpu.alloc(len(src));

  gpu.launch(scale, len(src), 64, alpha, dsrc, dout);

  print(gpu.read(dout));
  return 0;
}
