fn test_math_functions() {
    print("Testing math functions...");
    
    // Test basic operations
    a = 10;
    b = 3;
    
    print("min_int(10, 3): " + to_string_int(min_int(a, b)));
    print("max_int(10, 3): " + to_string_int(max_int(a, b)));
    print("abs_int(-5): " + to_string_int(abs_int(-5)));
    print("clamp_int(15, 0, 10): " + to_string_int(clamp_int(15, 0, 10)));
    
    // Test float operations
    x = 3.14159;
    y = 2.71828;
    
    print("min_float(3.14159, 2.71828): " + to_string_float(min_float(x, y)));
    print("max_float(3.14159, 2.71828): " + to_string_float(max_float(x, y)));
    print("abs_float(-2.5): " + to_string_float(abs_float(-2.5)));
    
    // Test trigonometric functions
    angle = PI / 4.0; // 45 degrees
    sin_val = sin(angle);
    cos_val = cos(angle);
    
    print("sin(π/4): " + to_string_float(sin_val));
    print("cos(π/4): " + to_string_float(cos_val));
    print("PI: " + to_string_float(PI));
    print("E: " + to_string_float(E));
}

