// Utility function to convert vector to string
fn vec_to_string(vec Vec<Int>) String {
    mut result = "[";
    mut i = 0;
    mut first = true;
    
    while i < vec_len(vec) {
        val = vec_get(vec, i);
        if val != none {
            if !first {
                result += ", ";
            }
            else {
                first = false;
            }
            val_int = (val as Int?) ?? 0;
            result += to_string_int(val_int);
        }
        else {}
        i += 1;
    }
    
    result += "]";
    return result;
}
