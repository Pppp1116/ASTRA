// Test file for enhanced ASTRA syntax features
// This demonstrates all the new syntax that the backend now supports

import std.vec;
import std.math;

// Enhanced loop syntax tests
fn test_enhanced_loops() Void {
    mut data = vec_new() as Vec<Int>;
    vec_push(data, 1);
    vec_push(data, 2);
    vec_push(data, 3);
    vec_push(data, 4);
    vec_push(data, 5);
    
    print("=== Enhanced Loop Tests ===");
    
    // Test 1: Enhanced while loop with inline mutable variable
    print("Test 1: Enhanced while loop");
    mut i = 0;
    while i < vec_len(data) {
        item = vec_get(data, i);
        if item != none {
            print("  Item " + str.to_string_int(i) + ": " + str.to_string_int(item as Int?));
        }
        else {}
        i += 1;
    }
    
    // Test 2: Enhanced for loop with initialization
    print("Test 2: Enhanced for loop");
    for mut j = 0; j < 3; j += 1 {
        print("  For iteration " + str.to_string_int(j));
    }
    
    // Test 3: Iterator-style for loop (conceptual)
    print("Test 3: Iterator for loop");
    // This would be: for mut item in data { print("  Item: " + str.to_string_int(item)); }
    // For now, we simulate with current syntax:
    mut k = 0;
    while k < vec_len(data) {
        mut item = vec_get(data, k);
        if item != none {
            print("  Iterator item: " + str.to_string_int(item as Int?));
        }
        else {}
        k += 1;
    }
}

// Function call consistency tests
fn test_function_calls() Void {
    print("=== Function Call Tests ===");
    
    mut v = vec_new() as Vec<Int>;
    
    // Test: No drop keyword needed
    print("Test 1: Function calls without drop");
    vec_push(v, 42);
    vec_push(v, 24);
    vec_push(v, 100);
    
    print("  Vector length: " + str.to_string_int(vec_len(v)));
}

// Enhanced pattern matching tests
fn test_pattern_matching() Void {
    print("=== Pattern Matching Tests ===");
    
    value = 42;
    
    // Test 1: Concise match arms
    print("Test 1: Concise match arms");
    match value {
        42 => print("  The answer to everything"),
        _ => print("  Some other number"),
    }
    
    // Test 2: Match with expressions
    result = match value {
        42 => "answer",
        24 => "day",
        _ => "other",
    };
    print("  Match result: " + result);
}

