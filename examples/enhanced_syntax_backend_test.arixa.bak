// Test struct for examples
struct Point {
    x Float,
    y Float,
}

// Helper functions
fn is_even(value Int) Bool {
    return value % 2 == 0;
}

fn double(value Int) Int {
    return value * 2;
}

fn risky_operation() Void {
    print("  Performing risky operation...");
}

// Main test function
fn main() Int {
    print("=== Enhanced ASTRA Syntax Backend Test ===");
    print("");
    
    test_enhanced_loops();
