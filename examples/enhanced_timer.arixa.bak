// Enhanced Timer Example - Demonstrating improved syntax
// This is how timer.arixa would look with the proposed syntax enhancements

import std.time;

// Enhanced function definition with expression syntax
fn ms() Int = __monotonic_ms()

// Enhanced main function with better control flow
fn main() Int {
    t0 = ms();
    
    // Enhanced loop with inline mutable variable
    while mut i < 20000000 {
        x = x * 1.0000001 + 0.5;
        
        // Enhanced if expression
        should_reset = x > 1000000.0;
        if should_reset {
            x = x / 2.0;
        }
        else {}
        
        i += 1;
    }
    
    t1 = ms();
    dt = t1 - t0;
    
    // Enhanced function calls (no drop needed)
    print(dt);
    print(x);
    
    return 0;
}

// Enhanced version with method calls and type inference
fn enhanced_main() Int {
    t0 = time.monotonic_ms();
    
    // Enhanced for loop with initialization
    for mut i = 0; i < 20000000; i += 1 {
        x = x * 1.0000001 + 0.5;
        
        // Enhanced pattern matching
        match x > 1000000.0 {
            true => x = x / 2.0,
            false => {}, // no action needed
        }
    }
    
    t1 = time.monotonic_ms();
    dt = t1 - t0;
    
    // Method call syntax
    dt.print();
    x.print();
    
    return 0;
}

// Even more enhanced version with collection literals
fn ultra_enhanced_main() Int {
    // Vector literal
    measurements = [1000, 2000, 3000, 4000, 5000];
    
    // Enhanced for loop with iterator
    for mut measurement in measurements {
        // Enhanced if expression
        result = if measurement > 3000 { "high" } else { "normal" }
        print("Measurement " + str.to_string_int(measurement) + ": " + result)
    }
    
    return 0;
}
