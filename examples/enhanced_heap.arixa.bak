// Enhanced Heap Operations - Demonstrating improved loop syntax
// This shows how heap.arixa would look with proposed syntax enhancements

import std.vec;
import std.math;

// Enhanced heap merge function with improved loops
fn enhanced_heap_merge(heap1 Heap<T>, heap2 Heap<T>) Heap<T> {
    result = Heap {
        data: vec_new() as Vec<T>,
        heap_type: heap1.heap_type,
    };
    
    // Enhanced for loop with iterator for first heap
    for mut item in heap1.data {
        if item != none {
            vec_push(result.data, (item as T?));
        }
        else {}
    }
    
    // Enhanced for loop with iterator for second heap
    for mut item in heap2.data {
        if item != none {
            vec_push(result.data, (item as T?));
        }
        else {}
    }
    
    // Build heap from combined data
    result = heap_build_from_vec(result, result.data);
    return result;
}

// Enhanced heap sort with inline mutable variables
fn enhanced_heap_sort(data Vec<T>) Vec<T> {
    if vec_len(data) <= 1 {
        return data;
    }
    else {}
    
    // Build heap
    heap = heap_build_from_vec(Heap { data: data, heap_type: HEAP_MIN }, data);
    
    // Enhanced loop with inline mutable variable
    result = vec_new() as Vec<T>;
    while mut item = heap_extract(heap) {
        if item != none {
            vec_push(result, (item as T?));
        }
        else {}
    }
    
    return result;
}

// Enhanced priority queue operations
fn enhanced_priority_queue_demo() Void {
    // Enhanced vector literal
    items = [5, 1, 4, 2, 8, 3, 7, 6];
    
    // Enhanced for loop with iterator
    print("Original items:");
    for mut item in items {
        print("  " + str.to_string_int(item));
    }
    
    // Create priority queue
    queue = int_priority_queue_new();
    
    // Enhanced loop with inline mutable variable
    for mut i = 0; i < vec_len(items); i += 1 {
        int_priority_queue_push(queue, items[i]);
    }
    
    print("Priority queue operations:");
    
    // Enhanced loop with inline mutable variable
    while mut value = int_priority_queue_pop(queue) {
        if value != none {
            print("  Popped: " + str.to_string_int(value));
        }
        else {}
    }
}

// Enhanced median finder with better loops
fn enhanced_median_finder_demo() Void {
    // Enhanced vector literal
    stream = [5, 15, 1, 3, 8, 7, 9, 10, 6, 11, 4, 2, 12, 13, 14];
    
    finder = median_finder_new();
    
    // Enhanced for loop with iterator
    print("Running median:");
    for mut i = 0; i < vec_len(stream); i += 1 {
        median_finder_add(finder, stream[i]);
        median = median_finder_find_median(finder);
        
        if median != none {
            print("  Added " + str.to_string_int(stream[i]) + ", median: " + str.to_string_float(median as Float?));
        }
        else {}
    }
}

// Enhanced k-th smallest element finder
fn enhanced_kth_smallest_demo() Void {
    // Enhanced vector literal
    data = [7, 2, 1, 6, 8, 5, 3, 4, 9, 0];
    
    print("Finding k-th smallest elements:");
    
    // Enhanced for loop with range and step
    for mut k = 1; k <= 10; k += 2 {
        kth = heap_kth_smallest(data, k);
        if kth != none {
            print("  " + str.to_string_int(k) + "-th smallest: " + str.to_string_int(kth as Int?));
        }
        else {}
    }
}

// Enhanced heap utilities with better control flow
fn enhanced_heap_utilities_demo() Void {
    // Enhanced vector literal
    data = [3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5];
    
    // Enhanced if expressions
    is_empty = vec_len(data) == 0;
    print("Data is empty: " + str.to_string_bool(is_empty));
    
    size = vec_len(data);
    print("Data size: " + str.to_string_int(size));
    
    // Enhanced pattern matching
    category = if size < 5 { "small" } else if size < 10 { "medium" } else { "large" }
    print("Data category: " + category);
    
    // Enhanced method calls (conceptual)
    // data.print()  // instead of print(data)
    // size.print()  // instead of print(size)
    
    print("Data:");
    for mut i = 0; i < size; i += 1 {
        item = vec_get(data, i);
        if item != none {
            print("  [" + str.to_string_int(i) + "]: " + str.to_string_int(item as Int?));
        }
        else {}
    }
}

// Enhanced heap comparison demo
fn enhanced_heap_comparison_demo() Void {
    // Enhanced vector literals
    data1 = [1, 3, 5, 7, 9];
    data2 = [2, 4, 6, 8, 10];
    
    // Create heaps
    min_heap = heap_build_from_vec(Heap { data: data1, heap_type: HEAP_MIN }, data1);
    max_heap = heap_build_from_vec(Heap { data: data2, heap_type: HEAP_MAX }, data2);
    
    print("Min-heap extraction:");
    // Enhanced loop with inline mutable variable
    while mut item = heap_extract(min_heap) {
        if item != none {
            print("  " + str.to_string_int(item as Int?));
        }
        else {}
    }
    
    print("Max-heap extraction:");
    // Enhanced loop with inline mutable variable
    while mut item = heap_extract(max_heap) {
        if item != none {
            print("  " + str.to_string_int(item as Int?));
        }
        else {}
    }
}

// Enhanced main function demonstrating all improvements
fn main() Int {
    print("=== Enhanced Heap Operations Demo ===");
    print("");
    
    enhanced_priority_queue_demo();
    print("");
    
    enhanced_median_finder_demo();
    print("");
    
    enhanced_kth_smallest_demo();
    print("");
    
    enhanced_heap_utilities_demo();
    print("");
    
    enhanced_heap_comparison_demo();
    print("");
    
    print("=== Enhanced Heap Operations Complete ===");
    return 0;
}

